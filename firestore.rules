rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isTrainerOrAdmin() {
      return userRole() in ["trainer", "admin"];
    }
    function isAdmin() {
      return userRole() == "admin";
    }

    match /users/{uid} {
      // Lesen: eigenes Profil oder Trainer/Admin
      allow read: if request.auth != null
                  && (request.auth.uid == uid || isTrainerOrAdmin());

      // Eigenes Profil anlegen (Signup) — keine privilegierte Rolle selbst vergeben
      allow create: if request.auth != null && request.auth.uid == uid
                    && (!("role" in request.resource.data)
                        || request.resource.data.role == "user");

      // Eigenes Profil aktualisieren — aber NIEMALS das Feld `role` aendern
      // (schliesst die Privilege-Escalation: User kann sich nicht selbst zum Admin machen)
      allow update: if request.auth != null && request.auth.uid == uid
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(["role"]);

      // Admin darf Rollen setzen und das komplette User-Dokument verwalten
      allow create, update, delete: if request.auth != null && isAdmin();

      match /{subcollection}/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
        allow read: if request.auth != null && isTrainerOrAdmin();

        // Admin schreibt in alle Sub-Collections (Demo-Seed)
        allow write: if request.auth != null && isAdmin();
      }

      // Trainer + Admin verwalten Wettkaempfe (fightCamps) fuer ihre Schueler
      match /fightCamps/{campId} {
        allow read, write: if request.auth != null && isTrainerOrAdmin();
      }
    }

    // CollectionGroup-Query: zentraler Wettkampfbereich liest alle fightCamps
    // gym-weit ueber alle Schueler. Schreiben bleibt ueber den users-Pfad oben.
    match /{path=**}/fightCamps/{campId} {
      allow read: if request.auth != null && isTrainerOrAdmin();
    }

    // Gegner-DNA-Bibliothek (gym-weit geteilte Gegnerprofile).
    match /opponents/{opponentId} {
      allow read, write: if request.auth != null && isTrainerOrAdmin();
    }

    // Trainer-zugewiesene Trainingsinhalte (gym-weites Curriculum) — bewusst
    // fuer alle eingeloggten Mitglieder lesbar. Schreiben nur Trainer/Admin.
    match /trainingSessions/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isTrainerOrAdmin();
    }

    // Anonyme Technik-Aufruf-Zaehler: nur Hochzaehlen erlaubt (viewCount/lastViewed),
    // keine fremden Felder einschleusbar. Lesen nur Trainer/Admin.
    match /techniqueStats/{techniqueId} {
      allow read: if request.auth != null && isTrainerOrAdmin();
      allow create: if request.auth != null
                    && request.resource.data.keys().hasOnly(["viewCount", "lastViewed"]);
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(["viewCount", "lastViewed"]);
    }
  }
}
