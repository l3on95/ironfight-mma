rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isTrainerOrAdmin() {
      return userRole() in ["trainer", "admin"];
    }
    function isAdmin() {
      return userRole() == "admin";
    }

    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read: if request.auth != null && isTrainerOrAdmin();
      allow update: if request.auth != null && isAdmin()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["role"]);

      // Admin darf das komplette User-Dokument schreiben
      // (fuer updateAthleteProfile im Demo-Seed)
      allow write: if request.auth != null && isAdmin();

      match /{subcollection}/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
        allow read: if request.auth != null && isTrainerOrAdmin();

        // Admin schreibt in alle Sub-Collections (Demo-Seed)
        allow write: if request.auth != null && isAdmin();
      }

      // Trainer + Admin verwalten Fight-Camps fuer ihre Schueler
      match /fightCamps/{campId} {
        allow read, write: if request.auth != null && isTrainerOrAdmin();
      }
    }

    match /trainingSessions/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isTrainerOrAdmin();
    }

    match /techniqueStats/{document=**} {
      allow write: if request.auth != null;
      allow read: if request.auth != null && isTrainerOrAdmin();
    }
  }
}
